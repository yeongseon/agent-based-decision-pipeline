[run]
branch = True
source =
    src/abdp

[report]
fail_under = 100
show_missing = True
skip_covered = True
exclude_lines =
    pragma: no cover
    if __name__ == "__main__":
    if TYPE_CHECKING:
    ^\s*\.\.\.\s*$
partial_branches =
    pragma: no branch
    ^\s*(?:async\s+def|def)\b.*:\s*\.\.\.\s*$
